{
  "name": "ui-components",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/ui/components",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng-packagr -p libs/ui/components/ng-package.json -c libs/ui/components/tsconfig.lib.json",
        "outputs": ["{workspaceRoot}/dist/onyx-ui"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "jest libs/ui/components" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "eslint libs/ui/components",
          "stylelint \"libs/ui/components/**/*.scss\""
        ],
        "parallel": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/ui/components/tsconfig.json --noEmit"
      }
    }
  }
}
