{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "ng build docs" },
      "configurations": {
        "development": {
          "command": "ng build docs --configuration=development"
        }
      },
      "outputs": ["{workspaceRoot}/dist/docs"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "ng serve docs" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "jest apps/docs/src" }
    }
  }
}
